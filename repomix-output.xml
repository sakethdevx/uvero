name: Toolbox

on:
  push:
    branches:
      - main
      - codex/**
  pull_request:

jobs:
  validate-toolbox:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup Node
        uses: actions/setup-node@v4
        with:
          node-version: 22
          cache: npm

      - name: Install Dependencies
        run: npm ci

      - name: Check Toolbox Consistency
        run: npm run check:toolbox

      - name: Smoke Test Representative Toolbox Routes
        run: npm run test:toolbox-routes

      - name: Test Toolbox Runtime Status
        run: npm run test:toolbox-runtime-status

      - name: Test RAR to ZIP API Error Handling
        run: npm run test:rar-to-zip

      - name: Build
        run: npm run build
