    { value: 'shares', label: 'Shares / weights' }
]

const UPI_APP_REFERENCE_LINKS = [
    {
        label: 'Google Pay',
        url: 'https://play.google.com/store/apps/details?id=com.google.android.apps.nbu.paisa.user'
