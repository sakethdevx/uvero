# Supabase server
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# GitHub storage (backend only)
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BRANCH=main
# Supabase (client keys)
# You can set SUPABASE_URL and SUPABASE_ANON_KEY for client usage.
SUPABASE_ANON_KEY=your-anon-key

# When using service role for server-side operations (do NOT expose in browser)
# SUPABASE_SERVICE_KEY=your-service-role-key
