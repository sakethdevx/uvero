# Supabase server
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# PhotoDrop GitHub storage (backend only)
PHOTODROP_STORAGE_GITHUB_TOKEN=
PHOTODROP_STORAGE_GITHUB_OWNER=
PHOTODROP_STORAGE_GITHUB_REPO=
PHOTODROP_STORAGE_GITHUB_BRANCH=main
# Supabase (server)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Supabase public (client) anon key - only if you need client-side access
SUPABASE_ANON_KEY=your-anon-key

# Hugging Face inference token (store securely; do NOT commit real token)
# Used by /api/detect server route to call the HF inference API
HF_TOKEN=your_hf_token_here

# Face matching threshold (higher = looser matching, default 0.5)
# Example: FACE_MATCH_THRESHOLD=0.8
FACE_MATCH_THRESHOLD=0.5
