# Supabase server
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# PhotoDrop GitHub storage (backend only)
PHOTODROP_STORAGE_GITHUB_TOKEN=
PHOTODROP_STORAGE_GITHUB_OWNER=
PHOTODROP_STORAGE_GITHUB_REPO=
PHOTODROP_STORAGE_GITHUB_BRANCH=main

# PaySplit receipt storage (backend only)
# Preferred variables (used first)
PAYSPLIT_RECEIPTS_GITHUB_TOKEN=
PAYSPLIT_RECEIPTS_GITHUB_OWNER=
PAYSPLIT_RECEIPTS_GITHUB_REPO=uvero-paysplit-receipts-storage
PAYSPLIT_RECEIPTS_GITHUB_BRANCH=main
# Optional max upload size in bytes (default: 5242880 = 5MB)
PAYSPLIT_RECEIPT_MAX_UPLOAD_BYTES=5242880

# Legacy fallback variables (optional)
# TRIPSPLIT_RECEIPTS_GITHUB_TOKEN=
# TRIPSPLIT_RECEIPTS_GITHUB_OWNER=
# TRIPSPLIT_RECEIPTS_GITHUB_REPO=
# TRIPSPLIT_RECEIPTS_GITHUB_BRANCH=main
# GITHUB_RECEIPTS_TOKEN=
# GITHUB_RECEIPTS_OWNER=
# GITHUB_RECEIPTS_REPO=
# GITHUB_RECEIPTS_BRANCH=main
# Supabase (server)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Supabase public (client) anon key - only if you need client-side access
SUPABASE_ANON_KEY=your-anon-key

# Hugging Face — Face Processing (PhotoDrop)
# Used by /api/detect server route to call the HF face processing API
HF_FACEPROCESSING_TOKEN=your_hf_token_here
HF_FACEPROCESSING_URL=

# Hugging Face — Compiler API
HF_COMPILER_TOKEN=your_hf_token_here
HF_COMPILER_URL=

# Face matching threshold (higher = looser matching, default 0.5)
# Example: FACE_MATCH_THRESHOLD=0.8
FACE_MATCH_THRESHOLD=0.5

# Online Clipboard GitHub storage (backend only)
# Recommended: use separate repos for public and private clipboard content.
CLIPBOARD_PUBLIC_STORAGE_GITHUB_TOKEN=
CLIPBOARD_PUBLIC_STORAGE_GITHUB_OWNER=
CLIPBOARD_PUBLIC_STORAGE_GITHUB_REPO=clipboard-public-storage

CLIPBOARD_PRIVATE_STORAGE_GITHUB_TOKEN=
CLIPBOARD_PRIVATE_STORAGE_GITHUB_OWNER=
CLIPBOARD_PRIVATE_STORAGE_GITHUB_REPO=clipboard-private-storage

# Maintenance mode
# Set VITE_MAINTENANCE_MODE=true to show the maintenance page in the web app.
# The API router also respects this flag, and you can optionally override retry timing server-side.
VITE_MAINTENANCE_MODE=false
VITE_MAINTENANCE_TITLE=Uvero is getting a careful tune-up
VITE_MAINTENANCE_MESSAGE=We are updating core systems right now so your next session feels stable and smooth.
VITE_MAINTENANCE_ETA=We will be back soon
VITE_MAINTENANCE_DETAILS=New sessions, uploads, clipboard updates, and data changes are temporarily paused during maintenance.
MAINTENANCE_RETRY_AFTER=300

# Contact / Feedback form (FormSubmit — https://formsubmit.co/)
# Set this to the email address that should receive contact form submissions.
VITE_FORMSUBMIT_EMAIL=
